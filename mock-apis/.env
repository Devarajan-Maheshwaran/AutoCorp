# AutoCorp Mock API Server

PORT=3001

# Price Engine (accelerated time for demo)
# MS_PER_DAY: How many milliseconds = 1 simulated day (default: 10000 = 10s)
# TICK_INTERVAL: Price update frequency in ms (default: 2000 = 2s)
MS_PER_DAY=10000
TICK_INTERVAL=2000

# Freight Simulation
# MS_PER_SIM_HOUR: How many milliseconds = 1 simulated hour (default: 5000 = 5s)
MS_PER_SIM_HOUR=5000

# Blockchain (Polygon Amoy Testnet)
PLATFORM_WALLET=0xAutoCorpPlatformDemo
CHAIN_ID=80002
NETWORK=polygon_amoy

# Sales Simulation
PAYMENT_DELAY_MS=8000
