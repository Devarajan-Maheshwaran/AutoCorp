# data.gov.in API key — register free at https://data.gov.in
DATA_GOV_API_KEY=your_data_gov_in_api_key_here

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Ethereum Sepolia RPC (use https://rpc.sepolia.org or Alchemy/Infura Sepolia URL)
RPC_URL=https://rpc.sepolia.org

# Sepolia testnet private keys for each agent wallet (funded with Sepolia ETH)
PRICE_MONITOR_PRIVATE_KEY=0x...
PROCUREMENT_PRIVATE_KEY=0x...
SALES_PRIVATE_KEY=0x...

# Smart contract address deployed by Member 3 on Sepolia (fill after deployment)
BUSINESS_ENTITY_ADDRESS=

# Other agents' URLs (defaults shown — change if running on different ports/hosts)
PROCUREMENT_AGENT_URL=http://localhost:8003
LOGISTICS_AGENT_URL=http://localhost:8004
SALES_AGENT_URL=http://localhost:8005
ACCOUNTANT_AGENT_URL=http://localhost:8006
FOUNDER_AGENT_URL=http://localhost:8001
